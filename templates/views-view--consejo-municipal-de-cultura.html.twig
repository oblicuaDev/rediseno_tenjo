{#
  Plantilla: Contenedor Principal Vista Consejo Municipal de Cultura
  Archivo: views-view--consejo-municipal-de-cultura.html.twig
#}
<style>
  body, html { overflow-x: hidden; }
  .accordion-content { display: none; }
  .accordion-header .accordion-chevron { transition: transform 0.3s ease; }
  .accordion-header.activo .accordion-chevron { transform: rotate(180deg); }

  /* Estilos exactos para los botones de inscripción (Borde verde, texto oscuro) */
  .btn-outline-verde {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 12px 35px; border-radius: 50px; font-weight: 800; font-size: 0.95rem;
    text-decoration: none !important; transition: all 0.3s ease;
    border: 2px solid var(--verde-oscuro, #1a3c28);
    color: #002b49 !important; /* Azul muy oscuro/casi negro para el texto */
    background-color: transparent;
  }
  .btn-outline-verde svg {
    color: #000; /* Color del icono */
  }
  .btn-outline-verde:hover {
    background-color: var(--verde-oscuro, #1a3c28);
    color: #fff !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(26, 60, 40, 0.2);
  }
  .btn-outline-verde:hover svg {
    color: #fff;
  }
</style>

<div class="pagina-estatica-consejo">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

      <div class="page-hero-breadcrumb" style="margin-bottom: 20px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep">></span>
        <span>CONSEJO MUNICIPAL DE CULTURA</span>
      </div>

      <h1 style="color: #fff; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1.15; margin: 0;">
        Consejo Municipal <br>
        <span style="color: var(--acento, #D4A843);">de Cultura</span>
      </h1>

    </div>
  </div>

  {# --- 2. CONTENIDO --- #}
  <div class="container" style="max-width: 1100px; margin: 50px auto 100px auto; padding: 0 20px;">

    <div style="background-color: #F8F9F3; border-radius: 12px; padding: 30px; border: 1px solid #EBE9E0; margin-bottom: 50px;">
      <p style="font-size: 1.1rem; line-height: 1.6; color: #444; margin: 0;">
        El <strong>Consejo Municipal de Cultura</strong> es la mayor instancia de participación sectorial y de concertación entre la instancia pública de cultura, la sociedad civil y el sector artístico y cultural, encargada de liderar y asesorar al Gobierno Municipal en la formulación y ejecución de las políticas y la planificación de los procesos culturales.
      </p>
    </div>

    {# Inyección de los grupos (Normatividad y Acordeones) #}
    {{ rows }}

    {% if not rows %}
      <div style="text-align: center; padding: 40px; color: #666; border: 1px dashed #ccc; border-radius: 12px;">
        <p>No hay documentos publicados en esta sección actualmente.</p>
      </div>
    {% endif %}

    {# --- 3. BOTONES DE INSCRIPCIÓN (Al final de todo) --- #}
    <div style="display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; margin-top: 50px;">

      <a href="https://forms.office.com/r/R1eJTDpz78" target="_blank" rel="noopener" class="btn-outline-verde">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        INSCRIPCIÓN COMO VOTANTE
      </a>

      <a href="https://forms.office.com/r/HbzLB9VD4p" target="_blank" rel="noopener" class="btn-outline-verde">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        INSCRIPCIÓN COMO VEEDOR
      </a>

    </div>

  </div>
</div>
