<style>
  /* Soluciona el problema del hero que se sale de la pantalla (Scroll horizontal) */
  body, html { overflow-x: hidden; }

  /* Asegura que el contenido del acordeón inicie cerrado para el JS */
  .accordion-content { display: none; }

  /* Transición suave para el icono del acordeón */
  .accordion-header .accordion-chevron { transition: transform 0.3s ease; }
  .accordion-header.activo .accordion-chevron { transform: rotate(180deg); }

  /* Estilos base para la lista de documentos */
  .documentos-lista { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; }
  .documento-item { display: flex; align-items: center; gap: 15px; background: #fff; padding: 12px 18px; border-radius: 10px; text-decoration: none !important; border: 1px solid #EBE9E0; transition: transform 0.2s; color: #333; }
  .documento-item:hover { transform: translateY(-2px); box-shadow: 0 4px 10px rgba(0,0,0,0.03); }
</style>

