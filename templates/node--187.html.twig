      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
      padding: 35px 25px;
      display: flex;
      flex-direction: column;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      font-family: 'Montserrat', sans-serif;
    }

    .tarjeta-ente:hover {
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    }

    .ente-logo-wrapper {
      height: 100px;
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ente-logo {
      max-height: 100%;
      max-width: 80%;
      object-fit: contain;
    }

    .ente-titulo {
      color: var(--verde-oscuro, #1a3c28);
      font-size: 1.3rem;
      font-weight: 800;
      margin: 0 0 15px 0;
      text-align: center;
      line-height: 1.3;
    }

    .ente-meta {
      font-size: 0.95rem;
      color: #444;
      margin-bottom: 25px;
      flex-grow: 1; /* Empuja el botón siempre hacia abajo */
    }

    .ente-meta p {
      margin: 0 0 12px 0;
      line-height: 1.5;
    }

    .ente-meta strong {
      color: var(--verde-oscuro, #1a3c28);
      font-weight: 700;
    }

    .ente-boton {
      display: block;
      text-align: center;
      background: var(--verde-oscuro, #1a3c28);
      color: #fff !important;
      padding: 12px;
      border-radius: 6px;
      text-decoration: none !important;
      font-weight: 700;
      font-size: 0.9rem;
      transition: all 0.3s ease;
      margin-top: auto;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .ente-boton:hover {
      background: var(--acento, #D4A843);
      color: #111 !important;
    }
  </style>

