    /* Evitar scroll horizontal */
    body, html { overflow-x: hidden; }

    /* === ESTILOS PARA LA GRILLA Y TARJETAS === */
    .grilla-entes {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 30px;
      margin-top: 40px;
    }

    .tarjeta-ente {
      background: #fff;
      border-radius: 12px;
