{#
  Plantilla: Informaci&oacute;n sobre Decisiones que Pueden Afectar al P&uacute;blico
  Archivo: views-view--decisiones-afectan-publico.html.twig
  Vista: decisiones_afectan_publico
#}

<div class="pagina-estatica-decisiones">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

      <div class="page-hero-breadcrumb" style="margin-bottom: 20px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep">&gt;</span>
        <a href="/transparencia" style="color: #fff; text-decoration: none;">TRANSPARENCIA</a>
        <span class="sep">&gt;</span>
        <span>DECISIONES QUE AFECTAN AL P&Uacute;BLICO</span>
      </div>

      <h1 style="color: #fff; font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 800; line-height: 1.2; margin: 0;">
        Informaci&oacute;n sobre Decisiones que<br>
        <span style="color: var(--acento, #D4A843);">Pueden Afectar al P&uacute;blico</span>
      </h1>

    </div>
  </div>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <div class="container" style="max-width: 1100px; margin: 50px auto 100px auto; padding: 0 20px;">

    {# Texto Introductorio con datos de contacto #}
    <div style="background-color: #F8F9F3; border-radius: 12px; padding: 35px; border: 1px solid #EBE9E0; margin-bottom: 40px;">
      <p style="font-size: 1.1rem; line-height: 1.8; color: #444; margin-bottom: 25px;">
        El <strong>Instituto Municipal de Cultura y Turismo de Tenjo</strong>, pone a disposici&oacute;n del p&uacute;blico las decisiones, actos administrativos y dem&aacute;s documentos que pueden afectar al p&uacute;blico. Para cualquier aclaraci&oacute;n puede acercarse a las instalaciones del Instituto o bien comunicarse por medio de los canales institucionales:
      </p>

      <div style="display: flex; flex-wrap: wrap; gap: 16px; margin-bottom: 20px;">

        {# Correo #}
        <div style="display: flex; align-items: center; gap: 10px; background: #fff; border: 1px solid #EBE9E0; border-radius: 8px; padding: 12px 18px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          <span style="font-size: 0.95rem; color: #444;">
            <strong>Correo:</strong>
            <a href="mailto:institutodeculturayturismo@tenjo-cundinamarca.gov.co" style="color: var(--verde-oscuro, #1a3c28); text-decoration: none; word-break: break-all;">institutodeculturayturismo@tenjo-cundinamarca.gov.co</a>
          </span>
        </div>

        {# Tel&eacute;fonos #}
        <div style="display: flex; align-items: center; gap: 10px; background: #fff; border: 1px solid #EBE9E0; border-radius: 8px; padding: 12px 18px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          <span style="font-size: 0.95rem; color: #444;">
            <strong>Tel&eacute;fonos:</strong> 300 727 4898 &nbsp;|&nbsp; 300 727 8700
          </span>
        </div>

        {# Portal Web #}
        <div style="display: flex; align-items: center; gap: 10px; background: #fff; border: 1px solid #EBE9E0; border-radius: 8px; padding: 12px 18px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          <span style="font-size: 0.95rem; color: #444;">
            <strong>Portal:</strong>
            <a href="https://www.tenjoculturayturismo.gov.co" target="_blank" rel="noopener" style="color: var(--verde-oscuro, #1a3c28); text-decoration: none;">www.tenjoculturayturismo.gov.co</a>
          </span>
        </div>

      </div>

      {# Enlace horarios #}
      <a href="/es/noticias/horarios-de-atencion-instituto-municipal-de-cultura-y-turismo-de-tenjo" style="display: inline-flex; align-items: center; gap: 8px; background-color: var(--verde-oscuro, #1a3c28); color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-decoration: none;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        Ver horarios de atenci&oacute;n
      </a>
    </div>

    {# --- 3. DOCUMENTOS (FILAS DE LA VISTA) --- #}
    <h2 style="font-size: 1.8rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 25px 0; text-align: center; border-bottom: 2px solid #EBE9E0; padding-bottom: 10px;">
      Circulares
    </h2>

    {{ rows }}

    {% if not rows %}
      <div style="text-align: center; padding: 40px; color: #666; border: 1px dashed #ccc; border-radius: 12px;">
        <p>No hay documentos publicados actualmente.</p>
      </div>
    {% endif %}

  </div>
</div>