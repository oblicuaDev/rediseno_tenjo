{#
  Plantilla: Contenedor Principal Vista NORMATIVA ENTIDAD
  Archivo: views-view--normativa-entidad.html.twig
#}
<style>
  body, html { overflow-x: hidden; }
  .accordion-content { display: none; }
  .accordion-header .accordion-chevron { transition: transform 0.3s ease; }
  .accordion-header.activo .accordion-chevron { transform: rotate(180deg); }
</style>

<div class="pagina-estatica-normativa-entidad">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

      <div class="page-hero-breadcrumb" style="margin-bottom: 20px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep">></span>
        <a href="/transparencia" style="color: #fff; text-decoration: none;">TRANSPARENCIA</a>
        <span class="sep">></span>
        <span>NORMATIVA ENTIDAD</span>
      </div>

      <h1 style="color: #fff; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1.15; margin: 0;">
        Normativa de la <br>
        <span style="color: var(--acento, #D4A843);">Entidad</span>
      </h1>

    </div>
  </div>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <div class="container" style="max-width: 1100px; margin: 50px auto 100px auto; padding: 0 20px;">

    {# --- 3. ACORDEONES DINÁMICOS DE LA VISTA --- #}
    {# --- SUIN (Req. 4.2a) --- #}
    <div style="margin-bottom: 40px; background: #FCFAEF; border: 1px solid #EBE9E0; border-left: 4px solid var(--verde-oscuro, #1a3c28); border-radius: 12px; padding: 24px 28px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
      <div>
        <p style="font-weight: 800; color: var(--verde-oscuro, #1a3c28); font-size: 1.05rem; margin: 0 0 6px 0;">SUIN-Juriscol — Sistema Único de Información Normativa</p>
        <p style="color: #555; font-size: 0.9rem; margin: 0;">Consulte la normatividad colombiana vigente en el sistema oficial del Estado: leyes, decretos, resoluciones y demás actos administrativos.</p>
      </div>
      <a href="http://www.suin-juriscol.gov.co/" target="_blank" rel="noopener noreferrer"
         style="display: inline-flex; align-items: center; gap: 8px; background: var(--verde-oscuro, #1a3c28); color: #fff; text-decoration: none; padding: 11px 22px; border-radius: 8px; font-weight: 700; font-size: 0.9rem; white-space: nowrap;"
         aria-label="Ir al SUIN-Juriscol para consultar normatividad (abre en nueva ventana)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Ir a SUIN-Juriscol
      </a>
    </div>

    <h2 style="font-size: 1.8rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 25px 0; text-align: center; border-bottom: 2px solid #EBE9E0; padding-bottom: 10px;">
      Normativa por Año
    </h2>

    {# --- BUSCADOR POR PALABRA CLAVE --- #}
    <div style="margin-bottom: 30px;">
      <input
        id="buscador-normativa"
        type="search"
        placeholder="Buscador de normas de la entidad"
        style="width: 100%; padding: 13px 18px; border: 2px solid #EBE9E0; border-radius: 8px; font-size: 1rem; color: #333; outline: none; box-sizing: border-box; transition: border-color 0.2s ease;"
        aria-label="Buscador de normas de la entidad"
        onFocus="this.style.borderColor='var(--verde-oscuro, #1a3c28)'"
        onBlur="this.style.borderColor='#EBE9E0'"
      >
      <p id="buscador-sin-resultados" style="display:none; text-align:center; color:#666; margin-top:20px; padding: 20px; border: 1px dashed #ccc; border-radius: 12px;">
        No se encontraron normas para esa búsqueda.
      </p>
    </div>

    {{ rows }}

    {% if not rows %}
      <div style="text-align: center; padding: 40px; color: #666; border: 1px dashed #ccc; border-radius: 12px;">
        <p>No hay documentos de Normativa Entidad publicados actualmente.</p>
      </div>
    {% endif %}

  </div>
</div>

<script>
(function () {
  function normalizar(texto) {
    return texto.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  var input = document.getElementById('buscador-normativa');
  if (!input) return;

  input.addEventListener('input', function () {
    var termino = normalizar(this.value.trim());
    var acordeones = document.querySelectorAll('.pagina-estatica-normativa-entidad .accordion-item');
    var hayResultados = false;

    acordeones.forEach(function (acordeon) {
      var lista = acordeon.querySelector('.documentos-lista');
      var contenido = acordeon.querySelector('.accordion-content');
      var header = acordeon.querySelector('.accordion-header');

      if (!termino) {
        // Sin búsqueda: restaurar todo al estado original
        acordeon.style.display = '';
        if (contenido) contenido.style.display = '';
        if (header) header.classList.remove('activo');
        if (lista) {
          Array.from(lista.children).forEach(function (doc) {
            doc.style.display = '';
          });
        }
        return;
      }

      if (!lista) {
        acordeon.style.display = 'none';
        return;
      }

      // Filtrar documentos individuales dentro del acordeón
      var documentos = Array.from(lista.children);
      var coincidencias = 0;

      documentos.forEach(function (doc) {
        var texto = normalizar(doc.textContent);
        if (texto.includes(termino)) {
          doc.style.display = '';
          coincidencias++;
        } else {
          doc.style.display = 'none';
        }
      });

      if (coincidencias > 0) {
        acordeon.style.display = '';
        if (contenido) contenido.style.display = 'block';
        if (header) header.classList.add('activo');
        hayResultados = true;
      } else {
        acordeon.style.display = 'none';
      }
    });

    var sinResultados = document.getElementById('buscador-sin-resultados');
    if (sinResultados) sinResultados.style.display = (termino && !hayResultados) ? 'block' : 'none';
  });
})();
</script>
