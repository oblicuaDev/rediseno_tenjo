{#
/**
 * @file
 * Esqueleto Universal para Páginas Básicas (Transparencia, trámites, etc.)
 * Este archivo aplica el banner verde automáticamente a cualquier página básica.
 */
#}

<div class="main-page-template" style="width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw; overflow-x: hidden;">

  <section class="transparencia-hero" style="background: var(--verde-oscuro); color: #fff; padding: 60px 0; text-align: center;">
    <div class="container">
      
      {# Miga de pan dinámica #}
      <nav class="breadcrumb" aria-label="Miga de pan" style="margin-bottom: 20px; font-size: 0.85rem; opacity: 0.8;">
        <a href="/" style="color: #fff; text-decoration: none;">Inicio</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: var(--acento);">{{ label }}</span>
      </nav>

      {# Título Dinámico: Drupal pone aquí el título que escribas en el admin #}
      <h1 style="font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; margin: 0;">
        {{ label }}
      </h1>
      
      <div style="width: 60px; height: 4px; background: var(--acento); margin: 20px auto 0;"></div>
    </div>
  </section>

  <section class="page-content-wrapper" style="padding: 60px 0; background: var(--fondo);">
    <div class="container">
      {# Aquí es donde Drupal escupe lo que pegues en el editor (el HTML del acordeón) #}
      {{ content.body }}
    </div>
  </section>

</div>
