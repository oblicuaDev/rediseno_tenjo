{#
  Plantilla: Contenedor Principal Vista CONSEJO MUNICIPAL DE TURISMO
  Archivo: views-view--consejo_turismo.html.twig
#}
<style>
  body, html { overflow-x: hidden; }

  /* Acordeón — documentos del Consejo (estilo artenjo) */
  .accordion-content { display: none; }
  .accordion-header .accordion-chevron { transition: transform 0.3s ease; }
  .accordion-header.activo .accordion-chevron { transform: rotate(180deg); }

  .seccion-vista { margin-bottom: 60px; }
  .seccion-vista h2 {
    color: var(--verde-oscuro, #1a3c28);
    font-weight: 800; font-size: 1.8rem;
    margin: 0 0 25px 0; border-bottom: 2px solid #EBE9E0; padding-bottom: 10px;
  }

  /* Grid — Equipo del Consejo (estilo nuestro-equipo)
     El adjunto de Drupal inyecta un <div class="view-content"> propio,
     por eso el grid se aplica a ese nivel, igual que en .view-equipo-integrantes */
  .grilla-equipo .view-content {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)) !important;
    gap: 30px !important;
    margin-top: 20px !important;
  }
  .grilla-equipo .views-row {
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
  }
</style>

<div class="pagina-estatica-consejo">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="width: 100vw; max-width: 100vw; margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); background-color: var(--verde-medio, #1a3c28); padding: 80px 0 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      <div class="page-hero-breadcrumb" style="margin-bottom: 25px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/" style="color: #fff; text-decoration: none;">Inicio</a>
        <span class="sep">></span>
        <a href="/tenjo-turistico" style="color: #fff; text-decoration: none;">Tenjo Turístico</a>
        <span class="sep">></span>
        <span>Consejo Municipal de Turismo</span>
      </div>
      <h1 style="color: #fff; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin: 0 0 20px 0;">
        Consejo Municipal de <span style="color: var(--acento, #D4A843);">Turismo</span>
      </h1>
    </div>
  </div>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <div class="container" style="max-width: 1200px; margin: 60px auto 100px auto; padding: 0 20px; font-family: 'Montserrat', sans-serif;">

    <p style="font-size: 1.25rem; font-weight: 500; color: var(--verde-oscuro, #1a3c28); border-left: 4px solid var(--acento, #D4A843); padding-left: 20px; max-width: 900px; line-height: 1.8; margin-bottom: 60px;">
      El Consejo de Turismo de Tenjo es reconocido como organismo asesor y consultivo en la planificación, desarrollo y sostenibilidad de los procesos del sector de turismo que se llevan a cabo por la administración municipal.
    </p>

    {# --- SECCIÓN 1: NORMATIVIDAD — acordeones estilo artenjo --- #}
    <div class="seccion-vista">
      <h2>Normatividad del Consejo</h2>
      <div class="contenedor-documentos-consejo">
        {{ rows }}
        {% if not rows %}
          <div style="text-align: center; padding: 40px; color: #666; border: 1px dashed #ccc; border-radius: 12px;">
            <p>No hay documentos del Consejo publicados actualmente.</p>
          </div>
        {% endif %}
      </div>
    </div>

    {# --- SECCIÓN 2: MIEMBROS DEL EQUIPO — grid estilo nuestro-equipo --- #}
    <div class="seccion-vista" style="margin-top: 60px;">
      <h2>Miembros del Consejo Municipal de Turismo</h2>
      <div class="grilla-equipo">

      </div>
    </div>

  </div>
</div>
