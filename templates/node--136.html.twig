{# 
  Plantilla Estática para: Directorio de Entidades (1.6)
  Archivo: node--136.html.twig
#}
<style>
  /* Previene scroll horizontal indeseado */
  body, html { overflow-x: hidden; }
</style>

<div class="pagina-estatica-entidades">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      
      {# Migas de pan #}
      <div class="page-hero-breadcrumb" style="margin-bottom: 20px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep">></span>
        <a href="/transparencia" style="color: #fff; text-decoration: none;">TRANSPARENCIA</a>
        <span class="sep">></span>
        <span>ENTIDADES</span>
      </div>

      {# Título #}
      <h1 style="color: #fff; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1.15; margin: 0;">
        Directorio de <span style="color: var(--acento, #D4A843);">Entidades</span>
      </h1>
      
    </div>
  </div>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <div class="container" style="max-width: 1100px; margin: 50px auto 100px auto; padding: 0 20px;">
    
    {# Texto Introductorio #}
    <div style="background-color: #F8F9F3; border-radius: 12px; padding: 30px; border: 1px solid #EBE9E0; margin-bottom: 40px;">
      <p style="font-size: 1.1rem; line-height: 1.6; color: #444; margin: 0;">
        El Instituto Municipal de Cultura y Turismo de Tenjo publica el listado de entidades que integran el sector, rama u organismo, con acceso directo a su sitio web oficial.
      </p>
    </div>

    {# Cuadrícula de Entidades (Sin Logos) #}
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px;">

      {% set icono_externo %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      {% endset %}
      {% set icono_ente %}
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
      {% endset %}
      {% set card_style = "display: flex; align-items: center; justify-content: space-between; background-color: #fff; padding: 20px 25px; border-radius: 12px; text-decoration: none; border: 1px solid #EBE9E0; transition: transform 0.2s ease, box-shadow 0.2s ease;" %}
      {% set badge_style = "color: var(--acento, #D4A843); font-size: 0.8rem; font-weight: 800; display: flex; align-items: center; gap: 6px; flex-shrink: 0;" %}
      {% set icono_bg = "background-color: var(--verde-xclaro, #E8F0EA); width: 42px; height: 42px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;" %}

      {# 1. Alcaldía Municipal de Tenjo #}
      <a href="https://www.tenjo-cundinamarca.gov.co/Paginas/default.aspx" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Alcald&iacute;a Municipal de Tenjo</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 2. Concejo Municipal de Tenjo #}
      <a href="https://www.concejo-tenjo-cundinamarca.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Concejo Municipal de Tenjo</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 3. Ministerio de las Culturas, las Artes y los Saberes #}
      <a href="https://www.mincultura.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Ministerio de las Culturas, las Artes y los Saberes</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 4. Ministerio de Comercio, Industria y Turismo #}
      <a href="https://www.mincit.gov.co/inicio" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Ministerio de Comercio, Industria y Turismo</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 5. FONTUR #}
      <a href="https://fontur.com.co/es" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Fondo Nacional de Turismo &ndash; FONTUR</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 6. Gobernación de Cundinamarca #}
      <a href="https://www.cundinamarca.gov.co/home/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Gobernaci&oacute;n de Cundinamarca</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 7. Secretaría de Cultura de Cundinamarca #}
      <a href="https://www.idecut.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Secretar&iacute;a de Cultura de Cundinamarca</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 8. EMSERTENJO #}
      <a href="https://www.empsertenjo.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Empresa de Servicios P&uacute;blicos de Tenjo &ndash; EMSERTENJO</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 9. INDERTEN #}
      <a href="https://www.inderten-tenjo.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">Instituto Municipal del Deporte &ndash; INDERTEN</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

      {# 10. ESE Hospital Santa Rosa de Tenjo #}
      <a href="https://www.esehospitalsantarosa-tenjo-cundinamarca.gov.co/" target="_blank" rel="noopener" style="{{ card_style }}" onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 8px 20px rgba(0,0,0,0.04)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none';">
        <div style="display: flex; align-items: center; gap: 15px;">
          <div style="{{ icono_bg }}">{{ icono_ente }}</div>
          <span style="font-size: 1.05rem; font-weight: 700; color: #333;">ESE Hospital Santa Rosa de Tenjo</span>
        </div>
        <span style="{{ badge_style }}">PORTAL WEB {{ icono_externo }}</span>
      </a>

    </div>
  </div>
</div>