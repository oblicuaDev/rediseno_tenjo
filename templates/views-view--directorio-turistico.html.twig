{#
  Plantilla: Contenedor Principal Directorio Turístico
  Corrige el alineamiento de las tarjetas para que sea igual a "Nuestro Equipo"
#}
<style>
  body, html { overflow-x: hidden; }

  /* Forzamos la grilla de 3 columnas como en la página de la biblioteca */
  .view-directorio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
    margin: 40px 0;
  }

  /* Corregimos el "movido a la derecha": reseteamos cualquier estilo de fila de Drupal */
  .view-directorio-grid .views-row {
    margin: 0 !important;
    padding: 0 !important;
    display: flex;
    justify-content: center;
  }

  /* Diseño de la tarjeta vertical (Estilo Nuestro Equipo) */
  .tarjeta-integrante {
    background: #ffffff;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    transition: transform 0.3s ease;
    width: 100%;
    max-width: 350px;
    border: 1px solid #eee;
    text-align: center; /* Centramos el contenido como en la biblioteca */
  }

  .tarjeta-integrante:hover {
    transform: translateY(-10px);
  }

  .tarjeta-foto {
    width: 100%;
    height: 250px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .tarjeta-foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tarjeta-info {
    padding: 25px 20px;
  }

  .tarjeta-cargo {
    display: block;
    font-size: 0.75rem;
    font-weight: 800;
    color: var(--verde-oscuro, #1a3c28);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }

  .tarjeta-nombre {
    font-size: 1.25rem;
    font-weight: 800;
    color: #333;
    margin-bottom: 15px;
    line-height: 1.2;
  }
</style>

<div class="pagina-directorio-completa">

  {# --- HERO VERDE --- #}
  <div class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; background-color: var(--verde-medio); padding: 60px 0; color: #ffffff;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      <div style="margin-bottom: 20px; font-size: 0.85rem; opacity: 0.7;">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a> > DIRECTORIO TURÍSTICO
      </div>
      <h1 style="color: #fff; font-size: 3rem; font-weight: 800; margin: 0;">
        Directorio <span style="color: #D4A843;">Turístico</span>
      </h1>
    </div>
  </div>

  {# --- CONTENIDO DE LA VISTA --- #}
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    <div class="view-directorio-grid">
      {{ rows }}
    </div>

    {% if pager %}
      <div style="margin-top: 50px;">{{ pager }}</div>
    {% endif %}
  </div>

</div>
