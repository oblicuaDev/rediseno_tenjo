{# 
  Plantilla: Contenedor Principal para Rendición de Cuentas
  Archivo: views-view--rendicion-de-cuentas.html.twig
#}

<style>
  /* Previene el scroll horizontal */
  body, html { overflow-x: hidden; }
  
  /* Estilos del texto introductorio */
  .contenido-estatico p { margin-bottom: 25px; font-size: 1.15rem; line-height: 1.8; color: #444; text-align: justify; }
  
  /* Estilos del Acordeón Dinámico */
  .rendicion-accordion { border: 1px solid #EBE9E0; border-radius: 12px; background: #fff; overflow: hidden; margin-bottom: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); transition: box-shadow 0.3s; }
  .rendicion-accordion:hover { box-shadow: 0 8px 25px rgba(0,0,0,0.06); }
  
  .rendicion-accordion-btn { width: 100%; text-align: left; display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; cursor: pointer; background: transparent; border: none; font-weight: 800; color: var(--verde-oscuro, #1a3c28); font-size: 1.25rem; transition: background 0.3s; }
  .rendicion-accordion-btn:hover { background: #FCFAEF; }
  
  .rendicion-chevron { color: var(--acento, #D4A843); transition: transform 0.3s ease; display: flex; align-items: center; justify-content: center; }
  .rendicion-accordion-btn.activo .rendicion-chevron { transform: rotate(180deg); }
  
  .rendicion-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease, padding 0.4s ease; background: #FCFAEF; padding: 0 25px; }
  .rendicion-content.activo { padding: 25px; max-height: 5000px; border-top: 1px solid #EBE9E0; }

  /* Lista interna de documentos */
  .documentos-lista { display: flex; flex-direction: column; gap: 12px; }
</style>

<div class="view-rendicion-cuentas">
  
  {# --- 1. HERO VERDE DE ANCHO COMPLETO --- #}
  <section class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 80px 0 60px 0; color: #ffffff;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      
      {# Migas de Pan #}
      <nav class="page-hero-breadcrumb" style="margin-bottom: 25px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/" style="color: #fff; text-decoration: none;">Inicio</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,18 15,12 9,6"/></svg>
        <span>TRANSPARENCIA</span>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,18 15,12 9,6"/></svg>
        <span>RENDICIÓN DE CUENTAS</span>
      </nav>
      
      {# Título Principal #}
      <h1 style="color: #fff; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin: 0 0 20px 0;">
        Rendición <span style="color: var(--acento, #D4A843);">de Cuentas</span>
      </h1>

    </div>
  </section>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <main class="container contenido-estatico" style="max-width: 900px; margin: 60px auto 100px auto; padding: 0 20px; font-family: 'Montserrat', sans-serif;">
    
    <p>
      El Instituto Municipal de Cultura y Turismo de Tenjo dando cumplimiento a la ley 1712 de 2014 de Transparencia y acceso a la información crea el siguiente espacio con el fin de dar a conocer a la comunidad los informes de gestión del Instituto.
    </p>

    {# Renderizado dinámico de la Vista (Acordeones y Documentos) #}
    <div class="view-content" style="margin-top: 40px;">
      {{ rows }}
    </div>

    {# Paginador (Si aplica) #}
    {% if pager %}
      <div style="margin-top: 40px; display: flex; justify-content: center;">
        {{ pager }}
      </div>
    {% endif %}

  </main>

</div>
