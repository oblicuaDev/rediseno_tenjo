{# 1. Buscamos la URL de la imagen usando field_image #}
{% set uri = '' %}

{# Intentamos extraer la URI si es un campo de imagen normal #}
{% if row._entity.field_image.entity.uri.value %}
  {% set uri = row._entity.field_image.entity.uri.value %}

{# Intentamos extraer la URI si es un campo de Multimedia (Media) #}
{% elseif row._entity.field_image.entity.field_media_image.entity.uri.value %}
  {% set uri = row._entity.field_image.entity.field_media_image.entity.uri.value %}
{% endif %}

{# Generamos la URL final #}
{% set bg_image = uri ? file_url(uri) : '' %}


{# 2. Contenedor visual del Slider #}
<div class="slide-inner" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('{{ bg_image }}'); background-size: cover; background-position: center;">
  
  <div class="container" style="height: 100%; display: flex; align-items: center; width: 100%; z-index: 2; position: relative;">
    
    <div class="hero-content" style="opacity: 1 !important; visibility: visible !important; transform: none !important; width: 100%; z-index: 5;">
      
      {# Título (Crudo para evitar enlaces automáticos de Drupal) #}
      <h1 class="hero-title" style="color: #ffffff; margin-bottom: 15px; font-weight: bold; font-size: clamp(2.5rem, 5vw, 4rem);">
        {{ row._entity.title.value }}
      </h1>

      {# Descripción #}
      {% if row._entity.field_descripcion.value %}
        <div class="hero-description" style="color: #ffffff; font-size: 1.2rem; margin-bottom: 25px; max-width: 600px;">
          {{ row._entity.field_descripcion.value|raw }}
        </div>
      {% endif %}

      {# Botón/Enlace #}
      {% if fields.field_enlace.content %}
        <div class="hero-actions custom-slider-btn">
          {{ fields.field_enlace.content }}
        </div>
      {% endif %}

    </div>
  </div>
</div>

{# 3. Estilos forzados para el botón #}
<style>
  .custom-slider-btn a {
    display: inline-block;
    padding: 12px 28px;
    background-color: var(--acento, #106b3a);
    color: #ffffff !important;
    border-radius: 6px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.1rem;
    transition: all 0.3s ease;
  }
  .custom-slider-btn a:hover {
    background-color: #0b4f2a;
    transform: translateY(-2px);
    color: #ffffff !important;
  }
</style>