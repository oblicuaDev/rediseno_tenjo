{# 
  Plantilla personalizada para la Vista: Nuestro Equipo.
  Inyecta el Hero verde de forma segura con estilos de ancho completo.
#}
<style>
  /* Evita scroll horizontal por el cálculo de 100vw */
  body, html { overflow-x: hidden; }

  /* Grid para las tarjetas de los integrantes */
  .view-equipo-integrantes .view-content {
    display: grid !important;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)) !important;
    gap: 30px !important;
    margin-top: 40px !important;
  }

  /* Reset de filas de Drupal para que no se muevan a la derecha */
  .view-equipo-integrantes .views-row {
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
  }
</style>

<div class="view-equipo-integrantes">
  
  {# --- INICIO DEL HERO VERDE (Ancho Completo) --- #}
  <div class="page-hero" style="width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 80px 0 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      
      <div class="page-hero-breadcrumb" style="margin-bottom: 25px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep" style="display: flex; align-items: center;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </span>
        <span>NUESTRO EQUIPO</span>
      </div>

      <h1 style="color: #fff; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin: 0 0 20px 0;">
        Nuestro <span style="color: var(--acento, #D4A843);">Equipo Biblioteca</span>
      </h1>
      
      <p class="page-hero-sub" style="font-size: 1.15rem; max-width: 850px; line-height: 1.6; opacity: 0.9; margin: 0;">
        Profesionales idóneos y comprometidos que guían los servicios, actividades y programas de la Biblioteca Municipal Isabel Murillo de Luque de Tenjo.
      </p>

    </div>
  </div>
  {# --- FIN DEL HERO VERDE --- #}

  {# --- CONTENIDO CENTRALIZADO --- #}
  <div class="container" style="max-width: 1200px; margin: 60px auto 100px auto; padding: 0 20px;">
    
    {# --- GRILLA DE TARJETAS --- #}
    <div class="view-content">
      {{ rows }}
    </div>

    {# --- PAGINADOR --- #}
    {% if pager %}
      <div style="margin-top: 50px; display: flex; justify-content: center;">
        {{ pager }}
      </div>
    {% endif %}

  </div>

</div>