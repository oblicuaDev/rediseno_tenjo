{#
  Plantilla: Escuela de Formación Artística y Cultural
  Archivo: node--211.html.twig
  Título desde {{ label }}, contenido administrable desde el campo body del nodo en Drupal
#}
<div class="pagina-estatica-escuela-formacion">

  {# --- HERO --- #}
  <section class="page-hero" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw); width: 100vw; max-width: 100vw; background-color: var(--verde-medio, #1a3c28); padding: 80px 0 60px 0; color: #ffffff;">
    <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">

      <nav class="page-hero-breadcrumb" style="margin-bottom: 25px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">Inicio</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,18 15,12 9,6"/></svg>
        <a href="/tenjo-cultural" style="color: #fff; text-decoration: none;">Tenjo Cultural</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9,18 15,12 9,6"/></svg>
        <span>Escuela de Formación</span>
      </nav>

      <h1 style="color: #fff; font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.1; margin: 0 0 20px 0;">
        {{ label }}
      </h1>

      <p style="font-size: 1.15rem; max-width: 850px; line-height: 1.6; opacity: 0.9; margin: 0;">
        Un espacio de aprendizaje, creación y expresión donde la comunidad tenjana desarrolla sus talentos a través del arte, la música, la danza, el teatro y las artes plásticas.
      </p>

    </div>
  </section>

  {# --- CONTENIDO DESDE DRUPAL (body del nodo) --- #}
  <main class="container" style="max-width: 1100px; margin: 60px auto 100px auto; padding: 0 20px; font-family: 'Montserrat', sans-serif;">
    {{ content.body }}
  </main>
</div>
