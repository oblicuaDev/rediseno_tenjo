{# 
  Plantilla Estática para: Participación Ciudadana
  Archivo: node--[ID].html.twig
#}
<div class="pagina-estatica-participacion">

  {# --- 1. HERO INSTITUCIONAL --- #}
  <div class="page-hero" style="width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw; background-color: var(--verde-medio, #1a3c28); padding: 60px 0; color: #ffffff;">
    <div class="container page-hero-inner" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      
      {# Migas de pan #}
      <div class="page-hero-breadcrumb" style="margin-bottom: 20px; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1px; display: flex; align-items: center; gap: 8px; color: rgba(255,255,255,0.7);">
        <a href="/es" style="color: #fff; text-decoration: none;">INICIO</a>
        <span class="sep">></span>
        <a href="#" style="color: #fff; text-decoration: none;">TENJO TURÍSTICO</a>
        <span class="sep">></span>
        <span>PARTICIPACIÓN CIUDADANA</span>
      </div>

      {# Título #}
      <h1 style="color: #fff; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; line-height: 1.15; margin: 0;">
        Participación <span style="color: var(--acento, #D4A843);">Ciudadana</span>
      </h1>
      <p style="color: rgba(255,255,255,0.8); max-width: 700px; font-size: 1.1rem; margin-top: 15px;">
        Te invitamos a participar activamente con tus consultas, aportes y sugerencias para seguir posicionando a Tenjo como un destino turístico bioseguro.
      </p>
    </div>
  </div>

  {# --- 2. CONTENIDO PRINCIPAL --- #}
  <div class="container" style="max-width: 1200px; margin: 60px auto 100px auto; padding: 0 20px;">
    
    <div style="display: flex; flex-wrap: wrap; gap: 60px; align-items: flex-start;">

      {# COLUMNA IZQUIERDA: INFORMACIÓN Y CANALES #}
      <div style="flex: 1.2; min-width: 300px; padding-top: 20px;">
        <h2 style="font-size: 1.8rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin-top: 0; margin-bottom: 20px;">Nuestros canales de atención</h2>
        <p style="font-size: 1.1rem; color: #444; line-height: 1.8; margin-bottom: 40px;">
          La Alcaldía y el Instituto Municipal de Cultura y Turismo de Tenjo valoran tus aportes. Puedes comunicarte con nosotros a través de los siguientes canales para contribuir a la mejora continua de nuestros proyectos.
        </p>

        {# Grid de Canales de Contacto #}
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">

          {# Presencial / Escrito #}
          <div style="background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #EBE9E0; box-shadow: 0 4px 15px rgba(0,0,0,0.03); display: flex; align-items: flex-start; gap: 15px;">
            <div style="background-color: var(--verde-xclaro, #E8F0EA); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
            <div>
              <h3 style="font-size: 1.1rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 5px 0;">Presencial y Escrito</h3>
              <p style="font-size: 0.95rem; color: #555; margin: 0; line-height: 1.5;">Centro Cultural Nhora Matallana Forero<br>Km 1 vía Tenjo – La Punta</p>
            </div>
          </div>

          {# Telefónico #}
          <div style="background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #EBE9E0; box-shadow: 0 4px 15px rgba(0,0,0,0.03); display: flex; align-items: flex-start; gap: 15px;">
            <div style="background-color: var(--verde-xclaro, #E8F0EA); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </div>
            <div>
              <h3 style="font-size: 1.1rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 5px 0;">Telefónico</h3>
              <p style="font-size: 0.95rem; color: #555; margin: 0; line-height: 1.5;">300 727 8700</p>
            </div>
          </div>

          {# Correo #}
          <div style="background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #EBE9E0; box-shadow: 0 4px 15px rgba(0,0,0,0.03); display: flex; align-items: flex-start; gap: 15px;">
            <div style="background-color: var(--verde-xclaro, #E8F0EA); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
            <div>
              <h3 style="font-size: 1.1rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 5px 0;">Correo Electrónico</h3>
              <a href="mailto:c.gomez@tenjoculturayturismo.gov.co" style="font-size: 0.95rem; color: #555; text-decoration: none; word-break: break-all;">c.gomez@tenjoculturayturismo.gov.co</a>
            </div>
          </div>

          {# Horario #}
          <div style="background: #fff; padding: 25px; border-radius: 12px; border: 1px solid #EBE9E0; box-shadow: 0 4px 15px rgba(0,0,0,0.03); display: flex; align-items: flex-start; gap: 15px;">
            <div style="background-color: var(--verde-xclaro, #E8F0EA); width: 45px; height: 45px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--verde-oscuro, #1a3c28)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            </div>
            <div>
              <h3 style="font-size: 1.1rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin: 0 0 5px 0;">Horario de Atención</h3>
              <p style="font-size: 0.95rem; color: #555; margin: 0; line-height: 1.5;">Lunes a Viernes<br>8:00 a.m. a 5:00 p.m.</p>
            </div>
          </div>

        </div>
      </div>

      {# COLUMNA DERECHA: FORMULARIO WEBFORM #}
      <div style="flex: 1; min-width: 300px;">
        <div style="background: #FCFAEF; border: 1px solid #EBE9E0; border-radius: 15px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.04);">
          <h3 style="font-size: 1.5rem; color: var(--verde-oscuro, #1a3c28); font-weight: 800; margin-top: 0; margin-bottom: 25px; text-align: center;">Formulario Virtual</h3>

          <div class="drupal-form-wrapper" style="background: #fff; padding: 30px; border-radius: 8px; border: 1px solid #eee;">
            
            {# 
              --- NOTA PARA LA INTEGRACIÓN DEL FORMULARIO ---
              Si tienes el módulo Twig Tweak instalado y creaste un Webform llamado 'participacion_ciudadana',
              puedes descomentar la siguiente línea para que el formulario aparezca aquí automáticamente:
              
              {{ drupal_entity('webform', 'participacion_ciudadana') }}
              
              O si prefieres incrustar el formulario desde la interfaz de usuario en el "Body" de la página,
              descomenta esta otra:
              
              {{ content.body }} 
            #}
            
            {# Mensaje temporal mientras configuras el form (reemplazando el error feo de WP) #}
            <div style="text-align: center; color: #666; padding: 20px 0;">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#ddd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 15px;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
              <p style="font-size: 0.95rem; margin: 0;">El formulario de participación se está configurando. Por favor, utiliza temporalmente nuestros otros canales de contacto.</p>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>

</div>