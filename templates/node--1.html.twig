        </a>

        <a href="https://portal.paco.gov.co/index.php?pagina=denuncie" target="_blank" rel="noopener" aria-label="PACO — Denuncie la corrupción">
          <img class="logo-aliado" src="https://tenjoculturayturismo.gov.co/wp-content/uploads/90851.png" alt="PACO — Denuncie la corrupción">
        </a>

      </div>
    </div>
  </section>

</article>
