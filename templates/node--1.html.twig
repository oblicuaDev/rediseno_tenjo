      <div class="logos-strip" data-reveal>

        <a href="https://www.dnp.gov.co/Prensa_/Podcast/Paginas/plan-nacional-de-desarrollo-colombia-potencia-mundial-de-la-vida.aspx" target="_blank" rel="noopener" aria-label="Plan Nacional de Desarrollo">
