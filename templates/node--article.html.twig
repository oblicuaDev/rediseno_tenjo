{#
  Plantilla para la interna de Noticias
  Archivo: node--article.html.twig
#}

{# Schema.org: NewsArticle JSON-LD #}
{% set _schema_noticia = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": node.title.value,
  "datePublished": node.field_fecha_de_la_noticia.value,
  "inLanguage": "es-CO",
  "author": {
    "@type": "Organization",
    "name": "Instituto Municipal de Cultura y Turismo de Tenjo",
    "url": "https://tenjoculturayturismo.gov.co"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Instituto Municipal de Cultura y Turismo de Tenjo",
    "url": "https://tenjoculturayturismo.gov.co",
    "logo": {
      "@type": "ImageObject",
      "url": "https://tenjoculturayturismo.gov.co/wp-content/themes/yootheme/cache/LOGO-DE-INSTITUTO-DE-CULTURA-02-33e32241.webp"
    }
  }
} %}
{% set _img_uri_noticia = node.field_image.entity.uri.value %}
{% if _img_uri_noticia %}
  {% set _schema_noticia = _schema_noticia|merge({"image": file_url(_img_uri_noticia)}) %}
{% endif %}
{% if node.field_categoria_de_la_noticia.entity.name.value %}
  {% set _schema_noticia = _schema_noticia|merge({"articleSection": node.field_categoria_de_la_noticia.entity.name.value}) %}
{% endif %}
<script type="application/ld+json">
{{ _schema_noticia|json_encode(448)|raw }}
</script>

<article class="noticia-interna-centrada" style="max-width: 900px; margin: 60px auto 100px auto; padding: 0 20px; font-family: 'Montserrat', sans-serif;">
  
  {# --- 1. CABECERA --- #}
  <header style="text-align: center; margin-bottom: 40px;">
    {% if node.field_categoria_de_la_noticia.entity.name.value %}
      <span style="background: #D4A843; color: #1a3c28; padding: 6px 16px; border-radius: 50px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; display: inline-block; margin-bottom: 15px;">
        {{ node.field_categoria_de_la_noticia.entity.name.value }}
      </span>
    {% endif %}
    
    <h1 style="font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 900; color: #111; line-height: 1.1; margin: 0 0 20px 0;">
      {{ label.0 }}
    </h1>

    <div style="display: flex; align-items: center; justify-content: center; gap: 10px; color: #777; font-weight: 600; font-size: 1rem;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
      <span>Publicado el {{ node.field_fecha_de_la_noticia.value|date('d') }} de {{ node.field_fecha_de_la_noticia.value|date('F')|replace({'January': 'Enero', 'February': 'Febrero', 'March': 'Marzo', 'April': 'Abril', 'May': 'Mayo', 'June': 'Junio', 'July': 'Julio', 'August': 'Agosto', 'September': 'Septiembre', 'October': 'Octubre', 'November': 'Noviembre', 'December': 'Diciembre'}) }}, {{ node.field_fecha_de_la_noticia.value|date('Y') }}</span>
    </div>
  </header>

  {# --- 2. IMAGEN PRINCIPAL --- #}
  {% if node.field_image.entity.uri.value %}
    <div class="noticia-foto-principal" style="width: 100%; border-radius: 20px; overflow: hidden; box-shadow: 0 15px 40px rgba(0,0,0,0.1); margin-bottom: 50px;">
      <img src="{{ file_url(node.field_image.entity.uri.value) }}" alt="{{ label.0 }}" style="width: 100%; height: auto; display: block;">
    </div>
  {% endif %}

  {# --- 3. CUERPO DE LA NOTICIA --- #}
  <div class="noticia-cuerpo" style="font-size: 1.2rem; line-height: 1.9; color: #333; text-align: justify;">
    {{ content.body }}
  </div>

  {# --- 4. PIE DE PÁGINA / REGRESAR --- #}
  <footer style="margin-top: 60px; padding-top: 30px; border-top: 1px solid #eee; text-align: center;">
    <a href="/noticias" style="display: inline-flex; align-items: center; gap: 10px; color: var(--verde-oscuro); text-decoration: none; font-weight: 800; text-transform: uppercase; font-size: 0.9rem; border: 2px solid var(--verde-oscuro); padding: 12px 30px; border-radius: 50px; transition: all 0.3s;" onmouseover="this.style.background='var(--verde-oscuro)'; this.style.color='#fff';" onmouseout="this.style.background='transparent'; this.style.color='var(--verde-oscuro)';">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Volver a todas las noticias
    </a>
  </footer>

</article>

<style>
  /* Estilos para elementos internos del body de Drupal */
  .noticia-cuerpo p { margin-bottom: 25px; }
  .noticia-cuerpo h2, .noticia-cuerpo h3 { 
    color: #1a3c28; 
    margin-top: 40px; 
    margin-bottom: 15px;
    font-weight: 800; 
  }
  .noticia-cuerpo img {
    border-radius: 12px;
    margin: 30px 0;
    max-width: 100%;
    height: auto;
  }
</style>